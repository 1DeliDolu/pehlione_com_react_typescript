NODE_ENV=development
PORT=4000
APP_NAME=pehlione-api
APP_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:4000

DATABASE_URL=mysql://pehlione_user:your_mysql_user_password@127.0.0.1:3307/pehlione_db_react

REDIS_URL=redis://127.0.0.1:6379

SESSION_SECRET=change_me_session_secret_at_least_32_chars_long
SESSION_NAME=pehlione.sid
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE=604800000

MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_FROM_NAME=Pehlione Dev
MAIL_FROM_ADDRESS=no-reply@pehlione.local

BCRYPT_SALT_ROUNDS=12

CSRF_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=debug
TZ=Europe/Berlin